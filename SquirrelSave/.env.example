# Database (MySQL / TiDB)
DATABASE_URL=mysql://piggy:piggy_pass@localhost:3306/piggy_coach

# Auth disabled for hackathon — guest user is auto-created (no env needed)

# LLM (OpenAI-compatible API — also works with Groq, OpenRouter, etc.)
LLM_API_URL=https://api.openai.com
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=32768
LLM_PARSER_CONFIDENCE_THRESHOLD=0.8
# When API fails (quota/rate limit), use local coach + parser (default: true in development)
LLM_FALLBACK_ENABLED=true

# Free alternative (Groq): https://console.groq.com
# LLM_API_URL=https://api.groq.com/openai
# LLM_API_KEY=gsk_your-groq-key
# LLM_MODEL=llama-3.1-8b-instant

# Legacy aliases (optional, same as LLM_*)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# App defaults
DEFAULT_CURRENCY=RM
VITE_APP_NAME=SquirryCoach
XP_PER_LEVEL=500
BUDGET_ALERT_THRESHOLD_PERCENT=80
