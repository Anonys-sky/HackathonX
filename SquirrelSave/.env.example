# ── SquirryCoach API (Python FastAPI) ────────────────────────────────────────
# Data: local JSON file (default) or Firebase Firestore
DATA_BACKEND=local
# DATA_BACKEND=firebase
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Demo / without-login user (judges)
DEMO_USER_ID=guest-demo-judge
DEMO_USER_NAME=Guest Judge

# LLM (OpenAI-compatible — Groq, Google AI Studio, etc.)
# Google AI Studio: https://aistudio.google.com/apikey
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/v1
LLM_API_KEY=your_gemini_or_groq_key_here
LLM_MODEL=gemini-2.0-flash
LLM_PARSER_CONFIDENCE_THRESHOLD=0.8
LLM_FALLBACK_ENABLED=true
# true = Squirry uses smart local replies (no API credits needed). Set false to call Gemini/Groq.
LLM_LOCAL_ONLY=true

# Groq free tier alternative:
# LLM_API_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your-groq-key
# LLM_MODEL=llama-3.1-8b-instant

DATA_BACKEND=local

# App
DEFAULT_CURRENCY=RM
COACH_NAME=SquirryCoach
VITE_APP_NAME=SquirryCoach
XP_PER_LEVEL=500
BUDGET_ALERT_THRESHOLD_PERCENT=80

# Optional: legacy Node/MySQL stack (npm run dev:legacy)
# DATABASE_URL=mysql://piggy:piggy_pass@localhost:3306/piggy_coach
# AUTO_START_MYSQL=true
